{
  "name": "myTradingBox",
  "version": "0.1.113",
  "private": true,
  "scripts": {
    "ng": "ng",
    "set-version": "node ./set-version.js",
    "release-notes:sync": "node ./scripts/generate-release-notes-mock.js",
    "start": "ng serve --host=127.0.0.1",
    "build": "npm run set-version && ng build",
    "build-prod": "npm run set-version && ng build --configuration production --output-hashing=all",
    "test": "ng test --watch=false --browsers=ChromeHeadless",
    "test:watch": "ng test --watch=true --browsers=Chrome",
    "test:watch:headless": "ng test --watch=true --browsers=ChromeHeadless",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "e2e": "ng e2e",
    "watch": "ng build --watch --configuration development",
    "deploy": "npm run set-version && node ./scripts/log-deploy.js && npm run release-notes:sync && ng build --configuration production --base-href=/MyTradingBox/ && npx angular-cli-ghpages --dir=dist/MyTradingBox/browser"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "dependencies": {
    "@angular/animations": "21.1.2",
    "@angular/common": "21.1.2",
    "@angular/compiler": "21.1.2",
    "@angular/core": "21.1.2",
    "@angular/forms": "21.1.2",
    "@angular/platform-browser": "21.1.2",
    "@angular/platform-browser-dynamic": "21.1.2",
    "@angular/pwa": "21.1.2",
    "@angular/router": "21.1.2",
    "@angular/service-worker": "21.1.2",
    "@auth0/angular-jwt": "5.2.0",
    "@ng-select/ng-select": "21.2.0",
    "@ngrx/store": "21.0.1",
    "@ngrx/store-devtools": "21.0.1",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "buffer": "6.0.3",
    "chart.js": "4.5.1",
    "chartjs-adapter-date-fns": "3.0.0",
    "chartjs-chart-financial": "0.2.1",
    "chartjs-plugin-annotation": "3.1.0",
    "chartjs-plugin-datalabels": "2.2.0",
    "chartjs-plugin-zoom": "2.2.0",
    "crypto-browserify": "^3.5.1",
    "crypto-js": "4.2.0",
    "date-fns": "4.1.0",
    "hammerjs": "2.0.8",
    "jwt-decode": "4.0.0",
    "ng2-charts": "8.0.0",
    "ngrx-store-localstorage": "20.1.0",
    "rxjs": "7.8.2",
    "stream-browserify": "3.0.0",
    "tslib": "2.8.1",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "21.0.3",
    "@angular-eslint/eslint-plugin": "21.2.0",
    "@angular-eslint/eslint-plugin-template": "21.2.0",
    "@angular-eslint/schematics": "21.2.0",
    "@angular-eslint/template-parser": "21.2.0",
    "@angular/build": "21.1.2",
    "@angular/cli": "21.1.2",
    "@angular/compiler-cli": "21.1.2",
    "@angular/language-service": "21.1.2",
    "@schematics/angular": "21.1.2",
    "@types/crypto-js": "4.2.2",
    "@types/jasmine": "6.0.0",
    "@types/jasminewd2": "2.0.13",
    "@types/node": "25.2.0",
    "@types/office-js": "1.0.569",
    "@types/webpack": "5.28.5",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "codelyzer": "^0.0.28",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jasmine-core": "6.0.1",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "node-polyfill-webpack-plugin": "^4.0.0",
    "prettier": "3.8.1",
    "prettier-eslint": "^1.0.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
