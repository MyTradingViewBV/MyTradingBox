{
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    }, {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**"
        ]
      }
    }
  ],
  "navigationUrls": [
    { "positive": true, "regex": "/.*" },
    { "positive": false, "regex": "/_\/.*/" },
    { "positive": false, "regex": "/[^#]+\.[^#]+$/" }
  ],
  "dataGroups": [
    {
      "name": "api",
      "urls": [
        "https://bot002api-gbh3hwe2egepfph6.swedencentral-01.azurewebsites.net/**",
        "/api/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1d",
        "timeout": "10s"
      }
    }
  ]
}
